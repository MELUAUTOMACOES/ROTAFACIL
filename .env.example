# ===========================================
# ROTA FÁCIL - Variáveis de Ambiente
# ===========================================
# Copie este arquivo para .env e preencha os valores

# 📦 BANCO DE DADOS (Supabase/PostgreSQL)
DATABASE_URL=postgresql://usuario:senha@host:porta/database

# 🔐 SEGURANÇA
# JWT_SECRET: Gere uma chave aleatória com pelo menos 32 caracteres
# Sugestão: openssl rand -hex 32
JWT_SECRET=sua_chave_super_secreta_minimo_32_caracteres_aqui

# ⚠️ MODO DESENVOLVIMENTO
# NUNCA use DEV_MODE=true em produção!
DEV_MODE=false

# 📧 EMAIL (Resend)
RESEND_API_KEY=re_xxxxxxxxxxxx
EMAIL_FROM=verificacao@seudominio.com
EMAIL_FROM_PASSWORD_RESET=novasenha@seudominio.com
EMAIL_FROM_INVITE=convite@seudominio.com
EMAIL_REPLY_TO=contato@seudominio.com

# 🌐 URL DA APLICAÇÃO
# Em desenvolvimento: http://localhost:5000
# Em produção: https://seu-app.onrender.com
APP_URL=http://localhost:5000

# 💬 WHATSAPP (Evolution API v2)
EVOLUTION_API_URL=http://localhost:8080
EVOLUTION_API_KEY=sua_apikey_global_aqui
EVOLUTION_INSTANCE=nome_da_instancia_aqui
